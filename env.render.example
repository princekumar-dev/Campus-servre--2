# Render Backend Environment Variables
# Add these in Render: campus-servre-2 > Environment.

NODE_ENV=production
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/Campusserve

# Generate independent random values of at least 32 bytes for each secret.
JWT_SECRET=replace_with_a_long_random_secret
PO_QR_SECRET=replace_with_a_different_long_random_secret

# Set both to the final Vercel frontend origin. These values make PO QR codes
# open the frontend gate verification page rather than the Render API host.
FRONTEND_URL=https://msec-campusserve.vercel.app
PUBLIC_BASE_URL=https://your-campusserve-project.vercel.app

# Web Push. Generate this matching pair with:
# npx web-push generate-vapid-keys
# Do not use the placeholder text below as deployed values.
VAPID_PUBLIC_KEY=replace_with_your_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_your_vapid_private_key
VAPID_SUBJECT=mailto:support@example.com

# Recommended email provider
RESEND_API_KEY=
RESEND_FROM=CampusServe <notifications@your-verified-domain.example>

# Optional SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_REQUIRE_TLS=true
SMTP_FORCE_IPV4=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Render injects PORT automatically. Do not hard-code PORT in production.
