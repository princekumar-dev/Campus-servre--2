# Local Development Environment Variables for MSEC CampusServe

# Development
NODE_ENV=development

# Database
MONGODB_URI=your_mongodb_connection_string_here

# Server
PORT=3001
PUBLIC_BASE_URL=http://localhost:3000

# JWT
JWT_SECRET=replace_with_a_long_random_secret
PO_QR_SECRET=replace_with_a_different_long_random_secret

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:3000

# Evolution API Configuration (WhatsApp Messaging)
EVOLUTION_API_URL=https://your-evolution-service.example.com
EVOLUTION_API_KEY=replace_with_your_evolution_api_key
EVOLUTION_INSTANCE_NAME=campusserve-notifications

# Web Push
VAPID_PUBLIC_KEY=replace_with_your_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_your_vapid_private_key

# Optional email provider (configure Resend or SMTP)
RESEND_API_KEY=
RESEND_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
