# Vercel Environment Variables
# Add these in Vercel: Project Settings > Environment Variables.

# Leave empty to use the /api proxy configured in vercel.json.
VITE_API_URL=
VITE_APP_NAME=MSEC CampusServe
VITE_APP_VERSION=1.0.0

# Vercel does not run the Express backend. Do not add MongoDB, JWT, SMTP,
# Resend, or VAPID private keys to the Vercel frontend project.
