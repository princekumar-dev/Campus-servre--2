# Production Environment Variables for Vercel Frontend
# Keep this empty so the browser uses same-origin /api requests. vercel.json
# securely proxies those requests to the Render backend.
VITE_API_URL=
VITE_APP_NAME=MSEC CampusServe
VITE_APP_VERSION=1.0.0

# Note: API calls will be proxied through Vercel to Render backend
# Frontend URL will be: https://your-app.vercel.app
# Backend URL is: https://campus-servre-2.onrender.com
